{
    "AllowedHosts": "*",
    "EnableE2ETestAuth": false,
    "Auth0": {
        "Authority": "https://wadnr.us.auth0.com/",
        "Audience": "WADNRAPI"
    },
    "Serilog": {
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
                }
            }
        ],
        "MinimumLevel": {
            "Default": "Warning"
        }
    }
}