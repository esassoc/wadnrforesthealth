# Legacy site comparison configuration
# Copy this file to .env and fill in the values

# Base URL of the legacy MVC site (required for comparison tests)
LEGACY_BASE_URL=https://wadnrforesthealth.qa.sitkatech.com

# Credentials for SAML authentication to the legacy site
# NOTE: Wrap values in double quotes if they contain special characters like #
LEGACY_USERNAME=
LEGACY_PASSWORD=

# Authentication method: "saw" (SecureAccess WA) or "adfs" (DNR employees)
LEGACY_AUTH_METHOD=saw
